---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDatetime: Date;
  tags: string[];
}

const { title, description, pubDatetime, tags } = Astro.props;
const published = new Intl.DateTimeFormat("en", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(pubDatetime);
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <header class="post-header">
      <a class="back-link" href="/">All posts</a>
      <time datetime={pubDatetime.toISOString()}>{published}</time>
      <h1>{title}</h1>
      <p>{description}</p>
      {
        tags.length > 0 && (
          <ul class="tag-list" aria-label="Tags">
            {tags.map((tag) => (
              <li>{tag}</li>
            ))}
          </ul>
        )
      }
    </header>
    <div class="prose">
      <slot />
    </div>
  </article>
</BaseLayout>
