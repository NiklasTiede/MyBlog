---
import BaseLayout from "../layouts/BaseLayout.astro";
import imdbScreenshot from "../../imdb-clone-screenshot.webp";

const projects = [
  {
    title: "IMDb Clone",
    description:
      "A full-stack movie app built around the original IMDb dataset, with search, accounts, ratings, watchlists, and comments.",
    image: imdbScreenshot,
    imageAlt: "Screenshot of the IMDb Clone web app",
    status: "Live demo",
    stack: ["Spring Boot", "React", "MySQL", "Elasticsearch", "Docker"],
    liveUrl: "https://imdb-clone.the-coding-lab.com",
    sourceUrl: "https://github.com/NiklasTiede/IMDb-Clone",
    articleUrl: "/2023/imdb-clone-backend/",
  },
];
---

<BaseLayout title="Projects" description="Selected software projects by Niklas Tiede.">
  <section class="hero reveal">
    <p class="eyebrow">Selected work</p>
    <h1>
      Projects that are
      <span class="grad-text">running for real.</span>
    </h1>
    <p class="lede">
      Web apps and engineering projects with source code, deployment notes, and live demos where available.
    </p>
  </section>

  <section class="projects" aria-label="Projects">
    {
      projects.map((project) => (
        <article class="project-card reveal">
          <a href={project.liveUrl} class="preview" aria-label={`Open ${project.title} live app`}>
            <img src={project.image.src} width={project.image.width} height={project.image.height} alt={project.imageAlt} />
          </a>
          <div class="body">
            <div class="head">
              <div>
                <p class="eyebrow project-label">Project</p>
                <h2>{project.title}</h2>
              </div>
              <span class="status">{project.status}</span>
            </div>
            <p class="desc">{project.description}</p>
            <div class="stack" aria-label={`${project.title} tech stack`}>
              {project.stack.map((item) => (
                <span>{item}</span>
              ))}
            </div>
            <div class="actions">
              <a href={project.liveUrl} class="button primary">Open live app</a>
              <a href={project.sourceUrl} class="button">View codebase</a>
              <a href={project.articleUrl} class="button">Read article</a>
            </div>
          </div>
        </article>
      ))
    }
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: 40px 30px;
  }

  .hero h1 {
    max-width: 11ch;
    margin-block: 12px 16px;
    font-size: clamp(38px, 7vw, 54px);
  }

  .lede {
    max-width: 58ch;
    color: var(--text-muted);
    font-size: 17px;
  }

  .projects {
    display: grid;
    gap: 24px;
    margin-top: 8px;
  }

  .project-card {
    overflow: hidden;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--bg-elevated);
  }

  .preview {
    display: block;
    overflow: hidden;
    border-bottom: 1px solid var(--border);
    background: var(--bg-elevated-2);
  }

  .preview img {
    width: 100%;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    object-position: top center;
    transition: transform 0.28s ease;
  }

  .preview:hover img {
    transform: scale(1.02);
  }

  .body {
    padding: 22px;
  }

  .head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 18px;
  }

  .project-label {
    margin-bottom: 7px;
    color: var(--text-faint);
  }

  h2 {
    font-size: clamp(27px, 5vw, 34px);
  }

  .status {
    flex: 0 0 auto;
    border: 1px solid color-mix(in srgb, var(--accent-teal) 45%, var(--border));
    border-radius: 999px;
    padding: 5px 9px;
    color: var(--accent-teal);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .desc {
    max-width: 58ch;
    margin-top: 12px;
    color: var(--text-muted);
    font-size: 16px;
  }

  .stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 18px;
  }

  .stack span {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 9px;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 22px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: 8px 11px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      color 0.15s ease,
      transform 0.15s ease;
  }

  .button:hover {
    border-color: var(--accent-teal);
    color: var(--accent-teal);
    transform: translateY(-1px);
  }

  .button.primary {
    border-color: transparent;
    background: var(--accent-teal);
    color: #09201d;
    font-weight: 700;
  }

  .button.primary:hover {
    color: #09201d;
  }

  @media (max-width: 560px) {
    .body {
      padding: 18px;
    }

    .head {
      flex-direction: column;
      gap: 12px;
    }

    .status {
      align-self: flex-start;
    }

    .button {
      width: 100%;
      justify-content: center;
    }
  }
</style>
