---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../consts";

const about = await getEntry("pages", "about");

if (!about) {
  throw new Error("Missing about page content");
}

const { Content } = await render(about);
---

<BaseLayout title={about.data.title} description={about.data.description}>
  <article class="about reveal">
    <header>
      <p class="eyebrow">About</p>
      <h1>The person behind <span class="grad-text">the lab.</span></h1>
    </header>
    <div class="body">
      <Content />
    </div>
    <nav class="social-links" aria-label="Profile links">
      <a href={SITE.social.github} rel="me">GitHub</a>
      <a href={SITE.social.linkedin} rel="me">LinkedIn</a>
    </nav>
  </article>
</BaseLayout>

<style>
  .about {
    padding-block: 40px 20px;
  }

  .about h1 {
    margin: 12px 0 24px;
    font-size: clamp(34px, 6vw, 46px);
  }

  .body {
    max-width: 58ch;
  }

  .body :global(p) {
    margin: 1em 0;
    color: var(--text-muted);
    font-size: 17px;
  }

  .body :global(a) {
    color: var(--accent-teal);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .body :global(img) {
    margin: 0 0 24px;
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .social-links a {
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 8px 11px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    text-decoration: none;
    transition:
      border-color 0.15s ease,
      color 0.15s ease;
  }

  .social-links a:hover {
    border-color: var(--border-strong);
    color: var(--accent-teal);
  }
</style>
