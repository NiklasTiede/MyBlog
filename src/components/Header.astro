---
import ThemeToggle from "./ThemeToggle.astro";
import { SITE } from "../consts";

const path = Astro.url.pathname;
const isActive = (href: string) => (href === "/" ? path === "/" : path.startsWith(href));
---

<header>
  <div class="wrap bar">
    <a href="/" class="brand">{SITE.title}</a>
    <nav aria-label="Primary navigation">
      <a href="/" class:list={["link", { active: isActive("/") }]}>Posts</a>
      <a href="/projects/" class:list={["link", { active: isActive("/projects") }]}>Projects</a>
      <a href="/about/" class:list={["link", { active: isActive("/about") }]}>About</a>
      <span class="profile-links">
        <a href={SITE.social.github} class="icon-link" rel="me" aria-label="GitHub profile">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M12 .5C5.7.5.6 5.6.6 11.9c0 5 3.3 9.3 7.8 10.8.6.1.8-.2.8-.6v-2c-3.2.7-3.9-1.4-3.9-1.4-.5-1.3-1.3-1.7-1.3-1.7-1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 .1.7 2.7 3.2 2 .1-.8.4-1.3.7-1.6-2.5-.3-5.2-1.3-5.2-5.6 0-1.2.4-2.2 1.2-3-.1-.3-.5-1.5.1-3 0 0 1-.3 3.1 1.2.9-.3 1.9-.4 2.9-.4s2 .1 2.9.4c2.2-1.5 3.1-1.2 3.1-1.2.6 1.5.2 2.7.1 3 .7.8 1.2 1.8 1.2 3 0 4.4-2.7 5.3-5.2 5.6.4.3.8 1 .8 2.1v3.1c0 .4.2.7.8.6 4.6-1.5 7.8-5.8 7.8-10.8C23.4 5.6 18.3.5 12 .5Z"
            ></path>
          </svg>
        </a>
        <a href={SITE.social.linkedin} class="icon-link" rel="me" aria-label="LinkedIn profile">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path
              d="M20.5 2h-17A1.5 1.5 0 0 0 2 3.5v17A1.5 1.5 0 0 0 3.5 22h17a1.5 1.5 0 0 0 1.5-1.5v-17A1.5 1.5 0 0 0 20.5 2ZM8 19H5V9h3v10ZM6.5 7.7A1.8 1.8 0 1 1 6.5 4a1.8 1.8 0 0 1 0 3.7ZM19 19h-3v-5.3c0-1.3-.5-2.1-1.6-2.1-.9 0-1.4.6-1.6 1.2-.1.2-.1.5-.1.8V19h-3V9h3v1.4c.4-.6 1.1-1.6 2.7-1.6 2 0 3.6 1.3 3.6 4.2v6Z"
            ></path>
          </svg>
        </a>
      </span>
      <ThemeToggle />
    </nav>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 10;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: saturate(160%) blur(10px);
  }

  .bar {
    display: flex;
    height: 62px;
    align-items: center;
    justify-content: space-between;
    gap: 22px;
  }

  .brand {
    color: var(--text);
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.02em;
    text-decoration: none;
  }

  nav {
    display: flex;
    align-items: center;
    gap: 22px;
  }

  .link {
    color: var(--text-muted);
    font-size: 14px;
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .link:hover,
  .link.active {
    color: var(--text);
  }

  .profile-links {
    display: flex;
    align-items: center;
    gap: 7px;
    margin-left: 2px;
    border-left: 1px solid var(--border);
    padding-left: 18px;
  }

  .icon-link {
    display: inline-flex;
    width: 29px;
    height: 29px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    color: var(--text-faint);
    text-decoration: none;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .icon-link:hover {
    background: var(--bg-elevated-2);
    color: var(--accent-teal);
  }

  .icon-link svg {
    width: 17px;
    height: 17px;
    fill: currentColor;
  }

  @media (max-width: 560px) {
    .bar {
      height: auto;
      align-items: flex-start;
      flex-direction: column;
      gap: 12px;
      padding-block: 14px;
    }

    nav {
      width: 100%;
      justify-content: space-between;
      gap: 12px;
    }

    .profile-links {
      margin-left: auto;
      padding-left: 12px;
    }

    .link {
      font-size: 13px;
    }
  }
</style>
